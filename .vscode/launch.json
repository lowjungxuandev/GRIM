{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter Debug (local)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/mobile",
      "args": ["--dart-define-from-file=.env.local"]
    },
    {
      "name": "Flutter Profile (local)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/mobile",
      "args": ["--dart-define-from-file=.env.local"]
    },
    {
      "name": "Flutter Release (local)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/mobile",
      "args": ["--dart-define-from-file=.env.local"]
    }
  ]
}
