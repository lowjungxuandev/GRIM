PORT=3001

# Cloudinary
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Firebase Admin / FCM / Realtime DB
# Set either a local credentials file path or a base64-encoded service-account JSON blob.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
FIREBASE_PROJECT_ID=
FIREBASE_DATABASE_URL=https://DATABASE_NAME.firebaseio.com
# Optional. FCM topic for Grim capture/import signals (default grim_new_result). Clients must subscribe to the same topic.
# GRIM_FCM_TOPIC=grim_new_result

# Optional shared defaults used by both stages when a stage-specific value is unset.
# LLM_PROVIDER=openrouter
# LLM_API_KEY=
# LLM_MODEL=openrouter/free
# LLM_BASE_URL=

# Extract stage LLM config
EXTRACT_LLM_PROVIDER=openrouter
EXTRACT_LLM_API_KEY=
EXTRACT_LLM_MODEL=openrouter/free
# Optional for openrouter (defaults to https://openrouter.ai/api/v1).
# Optional for openai (the official SDK default is used when unset).
# Required for nim (set this to your NIM /v1 base URL).
# EXTRACT_LLM_BASE_URL=

# Final text stage LLM config
FINAL_LLM_PROVIDER=openrouter
FINAL_LLM_API_KEY=
FINAL_LLM_MODEL=openrouter/free
# Optional for openrouter (defaults to https://openrouter.ai/api/v1).
# Optional for openai (the official SDK default is used when unset).
# Required for nim (set this to your NIM /v1 base URL).
# FINAL_LLM_BASE_URL=

# Legacy OpenRouter aliases are still accepted when neither stage-specific nor shared LLM vars are set.
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openrouter/free
# OPENROUTER_IMAGE_MODEL=openrouter/free

# Prompt files directory (must contain extract_text_prompt.txt and analyzing_text_prompt.txt). Default ./prompts from server cwd.
# GRIM_PROMPTS_DIR=/absolute/path/to/prompts
# Optional. When set, GET/PUT /api/v1/prompts require header X-Grim-Prompt-Secret with this exact value.
# GRIM_PROMPT_ADMIN_SECRET=

# Scalar — optional URL if you published this API to Scalar’s hosted API Reference.
# Local OpenAPI is always served at GET /openapi.yaml when the backend runs.
# SCALAR_DOCS_URL=https://your-workspace.scalar.com/...
