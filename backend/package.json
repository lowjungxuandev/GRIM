{
  "name": "backend",
  "version": "0.1.9",
  "private": true,
  "description": "Grim backend (Express + TypeScript)",
  "engines": {
    "node": ">=22"
  },
  "license": "UNLICENSED",
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon",
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
